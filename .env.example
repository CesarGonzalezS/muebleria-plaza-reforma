# Configuración de la Aplicación
# Copia este archivo a .env.local y configura según tu ambiente

# Modo de aplicación (development, production)
NODE_ENV=production

# URL de la API
VITE_API_URL=http://localhost:8080

# Habilitación de logs (solo en desarrollo)
VITE_DEBUG_MODE=false

# Configuración de seguridad
VITE_ENABLE_DEVTOOLS_DETECTION=true
VITE_DISABLE_RIGHT_CLICK=false
VITE_DISABLE_DEVTOOLS_SHORTCUTS=false

